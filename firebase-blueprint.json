{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A downloadable item with image, title, and link.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the post" },
        "imageUrl": { "type": "string", "description": "The URL of the thumbnail image" },
        "description": { "type": "string", "description": "Detailed description or instructions" },
        "downloadLink": { "type": "string", "description": "The external link for downloading the file" },
        "category": { "type": "string", "description": "The category of the item" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "views": { "type": "number" }
      },
      "required": ["title", "imageUrl", "downloadLink", "category", "createdAt", "authorId"]
    },
    "Category": {
      "title": "Category",
      "description": "A classification for posts.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "AppSetting": {
      "title": "AppSetting",
      "description": "Global application settings like notice and slider images.",
      "type": "object",
      "properties": {
        "notice": { "type": "string" },
        "sliderImages": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "joinedAt"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of downloadable posts."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of available categories."
    },
    "/settings/general": {
      "schema": "AppSetting",
      "description": "Single document for global site settings."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/admins/{userId}": {
      "schema": { "type": "object", "properties": { "email": { "type": "string" } } },
      "description": "Collection of authorized admin UIDs."
    }
  }
}
